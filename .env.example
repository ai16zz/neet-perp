# ── RPC ───────────────────────────────────────────────────────────────────────
RPC_URL=https://api.devnet.solana.com
# Use Helius or Triton for production:
# RPC_URL=https://rpc.helius.xyz/?api-key=YOUR_KEY

# ── Keeper ────────────────────────────────────────────────────────────────────
# JSON array of your keeper wallet secret key
KEEPER_KEYPAIR=[1,2,3,...]
MARKET_INDEX=0

# ── Oracles ───────────────────────────────────────────────────────────────────
# Pyth NEET/USD feed address (replace with real one when listed)
PYTH_NEET_FEED=GVXRSBjFk6e6J3NbVPXohDJetcTjaeeuykUpbQF8UoMU
# Switchboard aggregator
SB_NEET_FEED=CkMrDWtmFJZcmAUC11qNaWymbXQKvnRx4cq1QudLav7a

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_RPC_URL=https://api.devnet.solana.com
VITE_WS_URL=http://localhost:3001

# ── Deploy ────────────────────────────────────────────────────────────────────
DEPLOY_KEYPAIR=~/.config/solana/id.json
